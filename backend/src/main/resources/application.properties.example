spring.application.name=PetAdoptionSuppliesApplication
server.port=8081

# =========================
# Database (Render/Railway/etc)
# =========================
spring.datasource.url=${DB_URL:jdbc:mysql://localhost:3306/your_local_db}
spring.datasource.username=${DB_USER:root}
spring.datasource.password=${DB_PASSWORD:your_password}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# =========================
# JPA / Hibernate
# =========================
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# =========================
# JWT Configuration
# =========================
app.jwt.secret=${JWT_SECRET:your_very_long_local_secret_key_here}
app.jwt.expiration-ms=${JWT_EXPIRATION:86400000}

# =========================
# STRIPE CONFIGURATION
# =========================
stripe.api.key=${STRIPE_API_KEY:sk_test_your_local_stripe_key_here}
stripe.webhook.secret=${STRIPE_WEBHOOK_SECRET:whsec_your_local_webhook_secret}

# =========================
# Flyway Migration
# =========================
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true

# =========================
# Swagger UI
# =========================
springdoc.api-docs.path=/v3/api-docs
springdoc.swagger-ui.path=/swagger-ui.html

# =========================
# Logging
# =========================
logging.level.com.petmarketplace=DEBUG
logging.level.org.springframework.security=INFO
logging.level.org.flywaydb=INFO
